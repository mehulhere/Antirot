{
    "name": "openclaw-plugin-antirot",
    "version": "0.1.0",
    "description": "Strict coach accountability plugin for OpenClaw.",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/mehulhere/Antirot.git"
    },
    "bugs": {
        "url": "https://github.com/mehulhere/Antirot/issues"
    },
    "homepage": "https://github.com/mehulhere/Antirot#readme",
    "files": [
        "dist",
        "openclaw.plugin.json",
        "skills",
        "README.md",
        "LICENSE",
        "LICENSE-AGPL-3.0",
        "COMMERCIAL-LICENSE.md"
    ],
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "typecheck": "tsc --noEmit",
        "lint": "eslint ."
    },
    "openclaw": {
        "extensions": [
            "./dist/index.js"
        ],
        "compat": {
            "pluginApi": ">=2026.5.20",
            "minGatewayVersion": "2026.5.20"
        },
        "build": {
            "openclawVersion": "2026.5.20",
            "pluginSdkVersion": "2026.5.20"
        }
    },
    "keywords": [
        "openclaw",
        "plugin",
        "accountability",
        "adhd",
        "productivity"
    ],
    "license": "(AGPL-3.0-or-later OR LicenseRef-Antirot-Commercial)",
    "peerDependencies": {
        "openclaw": ">=2026.5.20"
    },
    "dependencies": {
        "typebox": "^1.0.58"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.1",
        "@types/node": "^22.19.1",
        "eslint": "^9.39.1",
        "openclaw": "^2026.5.20",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.46.4"
    }
}
